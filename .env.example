# ─── LLM Providers ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...              # only for text-embedding-3-small
GEMINI_API_KEY=AIza...

# ─── Voice ───────────────────────────────────────────────
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
PICOVOICE_ACCESS_KEY=              # for wake word, free at picovoice.ai

# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABC...   # from @BotFather
TELEGRAM_USER_ID=123456789            # your numeric ID — msg @userinfobot

# ─── Tools / Search ─────────────────────────────────────
BRAVE_API_KEY=                     # free tier at brave.com/search/api
TAVILY_API_KEY=tvly-...
SEARCH_BACKEND=duckduckgo          # options: duckduckgo, brave, google, tavily
SEARCH_MAX_RESULTS=5
GOOGLE_CALENDAR_CREDENTIALS_PATH=./data/gcal_creds.json

# ─── Internal Service URLs (local dev) ──────────────────
LITELLM_BASE_URL=http://localhost:4000
OLLAMA_BASE_URL=http://localhost:11434

# ─── App Config ──────────────────────────────────────────
DATA_DIR=./data
SESSION_MAX_TURNS=20
EMBEDDING_MODEL=text-embedding-3-small

# ─── Model Mapping (must match litellm/config.yaml) ─────
TIER1_MODEL=tier1
TIER2_MODEL=tier2
TIER3_MODEL=tier3

# ─── Timeouts & Retry ───────────────────────────────────
LLM_STREAM_TIMEOUT=30
LLM_COMPLETE_TIMEOUT=15
LLM_MAX_RETRIES=2

# ─── Scheduling ─────────────────────────────────────────
BRIEFING_HOUR=7
BRIEFING_MINUTE=30
TIMEZONE=Asia/Kolkata
